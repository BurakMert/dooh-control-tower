# Copy to .env (gitignored) and fill in.
POSTGRES_USER=dooh
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=dooh_control_tower
POSTGRES_HOST_PORT=5433

# App-side connection string (psycopg3 async driver). Must match the values
# above. Override at runtime via `uvicorn --env-file .env` (HTTP) or the `env`
# block of claude_desktop_config.json (stdio).
DATABASE_URL=postgresql+psycopg://dooh:change-me-in-real-env@localhost:5433/dooh_control_tower
